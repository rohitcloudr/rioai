# === DATABASE ===
# Local SQLite via Node 24+'s built-in node:sqlite module.
# Dev: leave DATABASE_PATH unset — the file at backend/data/rio.db is created
# on first run.
# Production: point DATABASE_PATH at a persistent disk so redeploys don't wipe
# the DB. e.g. on Render/Railway/Fly mount a volume at /data and set:
#   DATABASE_PATH=/data/rio.db
# DATABASE_PATH=

# === LLM PROVIDER ===
# Default provider when frontend doesn't specify one: openai | groq | gemini | github
LLM_PROVIDER=groq

# === API keys (set the ones you want; unconfigured providers won't show in UI) ===

# OpenAI — https://platform.openai.com/api-keys (paid only)
OPENAI_API_KEY=sk-paste-your-openai-key-here

# Groq — https://console.groq.com/keys (free, generous limits)
GROQ_API_KEY=gsk-paste-your-groq-key-here

# Google Gemini — https://aistudio.google.com/apikey (free, ~1M tokens/day)
GEMINI_API_KEY=paste-your-gemini-key-here

# GitHub Models — https://github.com/settings/tokens (free, ~50 requests/day)
# Generate a "Fine-grained personal access token" with no extra permissions, name it freely.
GITHUB_TOKEN=ghp-paste-your-github-pat-here

# === Voice (TTS) ===
# Rio's voice call uses Microsoft Edge TTS by default — completely free, no key.
# Optional: set TTS_PROVIDER=google or openai if you'd rather use a paid provider.
# TTS_PROVIDER=edge

# Google Cloud Text-to-Speech (paid — requires billing card on file even for free tier).
GOOGLE_TTS_API_KEY=paste-your-google-tts-key-here

# === FRIENDS ALERT EMAIL (Gmail) ===
# Used to email trusted friends when Rio detects a crisis/harm signal.
# 1. Use any Gmail account.
# 2. Enable 2-Step Verification: https://myaccount.google.com/security
# 3. Create an App Password: https://myaccount.google.com/apppasswords
#    (pick "Mail" as the app, "Other" as the device, name it "Rio")
# 4. Paste the 16-character password (spaces are OK) below.
# Until both are set, friends can be saved but alert emails won't send.
GMAIL_USER=your.account@gmail.com
GMAIL_APP_PASSWORD=paste-16-char-app-password-here
ALERT_FROM_NAME=Rio

# === ACCESS GATE ===
# Shared admin code required on the login screen before any OTP is sent.
# Distribute this code only to people you want to allow into the app. Wrong
# code = no email is sent. Leave empty (or unset) to disable the gate
# (dev / single-user convenience).
# Example: ADMIN_CODE=hello-rio-2026
ADMIN_CODE=rio2026

PORT=8787

# === FRONTEND ORIGIN (CORS) ===
# In production, set this to your deployed frontend's origin so CORS allows
# only your site (and credentials flow correctly). Leave empty in local dev
# to allow all origins.
# Single origin:
#   FRONTEND_URL=https://rio.vercel.app
# Multiple (comma-separated):
#   FRONTEND_URL=https://rio.vercel.app,https://rio.example.com
FRONTEND_URL=
